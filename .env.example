# ==============================================================================
# SUPPLIER CRM — ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to `.env` and fill in all values before running.
# NEVER commit the actual `.env` file to version control.
# ==============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
APP_SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_32
APP_DEBUG=false
APP_DOMAIN=localhost
APP_PORT=8000
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost"]

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost       # Overridden to "postgres" inside Docker
POSTGRES_PORT=5432
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=supplier_crm
# Constructed automatically by config.py — set manually if using external DB:
# DATABASE_URL=postgresql+asyncpg://crm_user:password@localhost:5432/supplier_crm

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost          # Overridden to "redis" inside Docker
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_DB=0
REDIS_BOT_FSM_DB=1           # Separate DB index for bot FSM state

# ── MinIO (Object Storage) ───────────────────────────────────────────────────
MINIO_HOST=localhost          # Overridden to "minio" inside Docker
MINIO_PORT=9000
MINIO_ROOT_USER=crm_minio_admin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
MINIO_BUCKET_DOCUMENTS=supplier-documents
MINIO_BUCKET_EXPORTS=crm-exports
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=http://localhost:9000   # External URL for presigned URLs

# ── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_FROM_BOTFATHER
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET_TOKEN
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/api/v1/bot/webhook
# Comma-separated list of allowed Telegram user IDs (whitelist middleware)
TELEGRAM_ALLOWED_USER_IDS=123456789,987654321

# ── JWT Authentication ────────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET_USE_OPENSSL_RAND_HEX_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── ARQ Worker ────────────────────────────────────────────────────────────────
ARQ_MAX_JOBS=10
ARQ_JOB_TIMEOUT=3600   # 1 hour max per job

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_EXPORT=3/minute
RATE_LIMIT_WEBHOOK=30/second

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json       # json | text
